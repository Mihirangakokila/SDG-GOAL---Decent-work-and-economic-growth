    "test:unit:auth": "jest --testPathPattern=authController.unit --no-coverage",
    "test:unit:application": "jest --testPathPattern=applicationController.unit --no-coverage",
    "test:unit:internship": "jest --testPathPattern=internshipController.unit --no-coverage",
    "test:unit:course": "jest --testPathPattern=courseController.unit --no-coverage",
    "test:integration:auth": "jest --testPathPattern=auth.integration --no-coverage",
    "test:integration:application": "jest --testPathPattern=application.integration --no-coverage",
    "test:integration:course": "jest --testPathPattern=course.integration --no-coverage",
    "test:integration:internship": "jest --testPathPattern=internshipRoute.test --no-coverage",
    "perf:auth": "npx artillery run src/tests/performance/auth.performance.yml",
    "perf:application": "npx artillery run src/tests/performance/application.performance.yml",
    "perf:internship": "npx artillery run src/tests/performance/internship.performance.yml",
