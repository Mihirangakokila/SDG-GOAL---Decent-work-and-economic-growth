{
  "testEnvironment": "node",
  "transform": {
    "^.+\\.js$": "babel-jest"
  },
  "testMatch": ["**/*.test.js"],
  "collectCoverageFrom": [
    "src/**/*.js",
    "!src/**/*.test.js",
    "!src/seed/**",
    "!node_modules/**"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 11,
      "functions": 15,
      "lines": 13,
      "statements": 13
    }
  }
}